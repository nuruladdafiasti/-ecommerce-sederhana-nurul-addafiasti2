<!-- ═══════════ SCRIPTS ═══════════ -->
<script>
    // ── Cart State ──
    let cart = [];

    // ── Toast System ──
    function showToast(message, type = 'success') {
        const container = document.getElementById('toastContainer');
        const toast = document.createElement('div');
        toast.className = 'toast';
        const icons = { success: '✓', info: 'ℹ', warn: '!' };
        toast.innerHTML = `<div class="toast-icon ${type}">${icons[type]}</div><span>${message}</span>`;
        container.appendChild(toast);
        setTimeout(() => {
            toast.classList.add('removing');
            setTimeout(() => toast.remove(), 300);
        }, 2800);
    }

    // ── Format Rupiah ──
    function formatRp(num) { return 'Rp ' + num.toLocaleString('id-ID'); }

    // ── Tambah ke Keranjang ──
    function tambahKeKeranjang(nama, harga) {
        // Ambil ukuran yang dipilih
        const activeSize = document.querySelector('.size-btn.active');
        const sizeText = activeSize ? ` (Size ${activeSize.textContent})` : '';
        const fullNama = nama + sizeText;

        const existing = cart.find(item => item.nama === fullNama);
        if (existing) {
            existing.qty++;
        } else {
            cart.push({ nama: fullNama, harga, qty: 1 });
        }
        updateCartUI();
        showToast(`${nama}${sizeText} ditambahkan ke keranjang!`, 'success');
    }

    // ── Update Cart UI ──
    function updateCartUI() {
        const totalItems = cart.reduce((sum, item) => sum + item.qty, 0);
        const totalPrice = cart.reduce((sum, item) => sum + (item.harga * item.qty), 0);

        const badge = document.getElementById('cartBadge');
        badge.textContent = totalItems;
        badge.style.opacity = totalItems > 0 ? '1' : '0';
        badge.classList.remove('badge-pulse');
        void badge.offsetWidth;
        badge.classList.add('badge-pulse');

        document.getElementById('cartEmpty').style.display = cart.length === 0 ? 'flex' : 'none';
        document.getElementById('cartFooter').style.display = cart.length > 0 ? 'block' : 'none';
        document.getElementById('cartTotal').textContent = formatRp(totalPrice);

        const listEl = document.getElementById('cartList');
        listEl.innerHTML = cart.map((item, i) => `
            <div class="glass-card rounded-2xl p-4 flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-white/5 flex items-center justify-center flex-shrink-0">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="font-medium text-sm truncate">${item.nama}</div>
                    <div class="text-white/40 text-xs mt-0.5">${formatRp(item.harga)} × ${item.qty}</div>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-emerald-400 font-medium text-sm">${formatRp(item.harga * item.qty)}</span>
                    <button onclick="removeFromCart(${i})" class="w-7 h-7 rounded-lg bg-white/5 hover:bg-red-500/20 hover:text-red-400 transition flex items-center justify-center text-white/30 text-xs flex-shrink-0">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    </button>
                </div>
            </div>
        `).join('');
    }

    function removeFromCart(index) {
        const removed = cart[index].nama;
        cart.splice(index, 1);
        updateCartUI();
        showToast(`${removed} dihapus dari keranjang`, 'warn');
    }

    // ── Cart Panel ──
    function openCartPanel() {
        if (cart.length === 0) { showToast('Keranjang masih kosong!', 'info'); return; }
        document.getElementById('cartPanel').style.transform = 'translateX(0)';
        document.getElementById('cartOverlay').style.opacity = '1';
        document.getElementById('cartOverlay').style.pointerEvents = 'auto';
        document.body.style.overflow = 'hidden';
    }
    function closeCartPanel() {
        document.getElementById('cartPanel').style.transform = 'translateX(100%)';
        document.getElementById('cartOverlay').style.opacity = '0';
        document.getElementById('cartOverlay').style.pointerEvents = 'none';
        document.body.style.overflow = '';
    }

    function checkout() {
        const totalItems = cart.reduce((sum, item) => sum + item.qty, 0);
        const totalPrice = cart.reduce((sum, item) => sum + (item.harga * item.qty), 0);
        showToast(`Checkout ${totalItems} produk (${formatRp(totalPrice)}) — Terima kasih!`, 'success');
        cart = [];
        updateCartUI();
        closeCartPanel();
    }

    // ── Mobile Menu ──
    function toggleMobile() {
        const menu = document.getElementById('mobileMenu');
        const btn = document.getElementById('hamburgerBtn');
        menu.classList.toggle('open');
        btn.classList.toggle('active');
        document.body.style.overflow = menu.classList.contains('open') ? 'hidden' : '';
    }
    function closeMobile() {
        document.getElementById('mobileMenu').classList.remove('open');
        document.getElementById('hamburgerBtn').classList.remove('active');
        document.body.style.overflow = '';
    }

    // ── Navbar Scroll ──
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
        navbar.classList.toggle('nav-scrolled', window.scrollY > 60);
    });

    // ── Scroll Reveal ──
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));


    // ══════════════════════════════════
    // SIDEBAR FUNCTIONS
    // ══════════════════════════════════

    // ── Filter Products ──
    function filterProducts() {
        const checks = document.querySelectorAll('.sidebar-section .filter-check input[type="checkbox"]');
        const categories = [];
        checks.forEach(c => { if (c.checked) categories.push(c.value); });

        const maxPrice = parseInt(document.getElementById('priceRange').value);

        const cards = document.querySelectorAll('#productGrid .product-card');
        let visibleCount = 0;

        cards.forEach(card => {
            const cat = card.getAttribute('data-category');
            const price = parseInt(card.getAttribute('data-price'));
            const matchCat = categories.includes(cat);
            const matchPrice = price <= maxPrice;

            if (matchCat && matchPrice) {
                card.classList.remove('filtered-out');
                visibleCount++;
            } else {
                card.classList.add('filtered-out');
            }
        });

        document.getElementById('noResults').classList.toggle('hidden', visibleCount > 0);
    }

    // ── Price Label ──
    function updatePriceLabel() {
        const val = parseInt(document.getElementById('priceRange').value);
        document.getElementById('priceLabel').textContent = formatRp(val);
    }

    // ── Toggle Size ──
    function toggleSize(btn) {
        btn.classList.toggle('active');
    }

    // ── Toggle Color ──
    function toggleColor(swatch) {
        document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
        swatch.classList.add('active');
    }

    // ── Reset Filters ──
    function resetFilters() {
        document.querySelectorAll('.filter-check input').forEach(c => c.checked = true);
        document.getElementById('priceRange').value = 1000000;
        updatePriceLabel();
        filterProducts();
        showToast('Filter direset', 'info');
    }

    // ── Sidebar Mobile Toggle ──
    function toggleSidebarMobile() {
        const col = document.getElementById('sidebarCol');
        const btn = document.getElementById('sidebarToggleBtn');
        col.classList.toggle('mobile-open');
        const isOpen = col.classList.contains('mobile-open');
        btn.innerHTML = isOpen
            ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg> Tutup Filter`
            : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg> Filter & Pilih Ukuran`;
    }
</script>

